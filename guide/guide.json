  "strategy": [
    {
      "title": "Identifier les prospects",
      "detail": "Repérer les restaurants sans QR code, avec menu PDF périmé, ou très présents sur TheFork (signe de commissions élevées). Privilégier les indépendants avec 30+ couverts/soir."
    },
    {
      "title": "Accroche sans rendez-vous",
      "detail": "Entrer dans le restaurant ou contacter après avoir repéré 2-3 points faibles précis sur leur présence digitale actuelle. Proposer une démo gratuite de 15 minutes, sans vendre."
    },
    {
      "title": "Démo live",
      "detail": "Montrer le changement de prix en direct depuis le téléphone, générer un post Instagram, exporter le PDF. Ne pas parler de prix avant la fin de la démo.\nVidéo avec Rotato"
    },
    {
      "title": "Argument commissions TheFork",
      "detail": "Faire calculer au prospect ses commissions mensuelles. Comparer au forfait fixe Tensai. Insister sur la propriété des données clients."
    },
    {
      "title": "Proposer un essai",
      "detail": "Un mois à 0€ avec onboarding inclus pour lever l'objection du risque. Coût réel : le temps d'onboarding (2-3h si process rodé)."
    },
    {
      "title": "Closing et signature",
      "detail": "Contrat simple, premier prélèvement après la période d'essai. Formation incluse à la signature.\nSi vous signez dans la semaine, 1 mois offert"
    },
    {
      "title": "Phases clés",
      "detail": "- L'agence, c'est vous\n\"Vous maîtrisez votre image et vos contenus, sans dépendre d'un prestataire.\""
    },
    {
      "title": "Les offres",
      "detail": "Starter : Objectif : équiper un maximum de restaurants.\nGrowth : Objectif : faire gagner de l'argent au restaurant : Le système d'exploitation du restaurant. \nTu ajoutes tout ce qui génère du chiffre d'affaires. \n\nRéservation\nGestion des tables\nCRM\nFidélité\nCartes cadeaux\nAvis Google\nSMS\nEmail\nWhatsApp\nMarketing automation\nStatistiques\nDashboard\nCampagnes"
    }
  ]
